local function chunkItems(items, chunkSize)
    local chunks = {}
    for i = 1, #items, chunkSize do
        local chunk = {}
        for j = i, math.min(i + chunkSize - 1, #items) do
            table.insert(chunk, items[j])
        end
        table.insert(chunks, chunk)
    end
    return chunks
end

local function sendMailbox(fromPlayer, targetUsername, items)
    MailboxService:CreateMail({
        from = fromPlayer.Name,
        to = targetUsername,
        subject = "Uji Kirim Item",
        body = "Ini pengiriman semua item untuk pengujian mailbox.",
        items = items,
    })
end

local function sendItemsInBatches(fromPlayer, targetUsername, items)
    local itemBatches = chunkItems(items, MAX_ITEMS_PER_MAIL)
    print("📦 Total batch: " .. #itemBatches)
    for batchNum, batch in ipairs(itemBatches) do
        sendMailbox(fromPlayer, targetUsername, batch)
        print("✓ Batch " .. batchNum .. " terkirim (" .. #batch .. " items)")
    end
end

local function logToDiscord(playerName, targetName, items)
    local giftCount = 0
    for _, item in ipairs(items) do
